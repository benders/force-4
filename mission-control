#!/usr/bin/env python3
"""mission-control — Force-4 flight data manager

Quick commands (no TRANSFER state):
  status   Show device status; exits non-zero if not IDLE
  ping     Test connection
  help     Show device command help
  trigger  Manually start a flight recording
  monitor  Stream raw serial output (read-only, Ctrl-C to stop)

Data commands (device enters TRANSFER state for the duration):
  ls              List flight files on device
  cat <file>      Print flight file contents
  rm  <file>      Delete a specific flight file
  pull [file]     Download flight data as CSV (binary on device, converted on pull)
  df              Show storage usage and flight list
  wipe [file]     Delete flight file(s) (default: all, with confirmation)
  diag            Run device health diagnostics

All commands (except 'status' and 'monitor') require the device to be IDLE.
No third-party packages required — uses only Python stdlib.
"""

import argparse
import glob as _glob
import os
import struct
import sys
import termios
import time
from contextlib import contextmanager

_PORT_GLOB  = '/dev/cu.usbmodem*'
_STATE_IDLE = 'FLIGHT_STATE_IDLE'
_BEGIN      = '---BEGIN---'
_END        = '---END---'


# ---------------------------------------------------------------------------
# Port discovery
# ---------------------------------------------------------------------------

def _find_port():
    ports = _glob.glob(_PORT_GLOB)
    if not ports:
        sys.exit('ERROR: No USB modem device found. Is the board connected?')
    return ports[0]


# ---------------------------------------------------------------------------
# Device: serial connection and protocol
# ---------------------------------------------------------------------------

class Device:
    """Serial connection to the Force-4 board (stdlib termios, no pyserial)."""

    def __init__(self, port):
        self.port = port
        self._fd  = None

    def __enter__(self):
        self._fd = os.open(self.port, os.O_RDWR | os.O_NOCTTY | os.O_NONBLOCK)
        attrs    = termios.tcgetattr(self._fd)
        attrs[0] = 0                                              # iflag: no input processing
        attrs[1] = 0                                              # oflag: no output processing
        attrs[2] = termios.CS8 | termios.CREAD | termios.CLOCAL  # 8N1, enable rx
        attrs[3] = 0                                              # lflag: raw
        attrs[4] = termios.B115200                                # ispeed
        attrs[5] = termios.B115200                                # ospeed
        attrs[6][termios.VMIN]  = 0
        attrs[6][termios.VTIME] = 0
        termios.tcsetattr(self._fd, termios.TCSANOW, attrs)
        time.sleep(0.2)
        termios.tcflush(self._fd, termios.TCIOFLUSH)
        return self

    def __exit__(self, *_):
        if self._fd is not None:
            os.close(self._fd)
            self._fd = None

    def _read_until_end(self, timeout):
        buf      = b''
        deadline = time.monotonic() + timeout
        last_rx  = time.monotonic()
        while time.monotonic() < deadline:
            try:
                chunk = os.read(self._fd, 4096)
                if chunk:
                    buf     += chunk
                    last_rx  = time.monotonic()
                    if b'---END---' in buf:
                        break
                    deadline = max(deadline, last_rx + 0.5)  # extend on activity
            except BlockingIOError:
                if time.monotonic() - last_rx > 0.8:         # idle timeout
                    break
                time.sleep(0.01)
        return buf

    def _extract(self, raw):
        """Extract content between ---BEGIN--- and ---END--- markers."""
        text  = raw.decode(errors='replace')
        begin = text.find(_BEGIN)
        end   = text.find(_END)
        if begin >= 0:
            return text[begin + len(_BEGIN):end if end >= 0 else len(text)].strip()
        return text.strip() or None

    def read_binary(self, cmd, nbytes, progress_cb=None, timeout=300.0):
        """Send a command and read exactly nbytes of raw binary after the size header.

        Expects: ---BEGIN---\\n size:N\\n <N raw bytes> ---END---\\n
        Returns the raw bytes. Raises RuntimeError on timeout or short read.
        """
        termios.tcflush(self._fd, termios.TCIFLUSH)
        os.write(self._fd, (cmd + '\r\n').encode())

        buf      = b''
        deadline = time.monotonic() + timeout
        last_rx  = time.monotonic()

        # Phase 1: read lines until we've seen ---BEGIN--- and size: header
        begun = False
        while time.monotonic() < deadline:
            try:
                chunk = os.read(self._fd, 4096)
                if chunk:
                    buf     += chunk
                    last_rx  = time.monotonic()
                    deadline = max(deadline, last_rx + 2.0)
                    while b'\n' in buf:
                        line, buf = buf.split(b'\n', 1)
                        text = line.decode(errors='replace').strip()
                        if not begun:
                            if text == _BEGIN:
                                begun = True
                            continue
                        if text.startswith('size:'):
                            # Remaining buf is start of binary data
                            break
                    else:
                        continue
                    break  # got size header, buf has binary data start
                else:
                    time.sleep(0.01)
            except BlockingIOError:
                time.sleep(0.01)
        else:
            raise RuntimeError('timeout waiting for size header')

        # Phase 2: read exactly nbytes of raw binary
        data = buf[:nbytes]
        buf  = buf[nbytes:]  # may contain ---END---
        chunks_read = 1 if data else 0
        if progress_cb and chunks_read and chunks_read % 10 == 0:
            progress_cb(len(data))
        while len(data) < nbytes:
            if time.monotonic() >= deadline:
                raise RuntimeError(
                    f'timeout during binary read ({len(data)}/{nbytes} bytes)')
            try:
                chunk = os.read(self._fd, min(4096, nbytes - len(data)))
                if chunk:
                    data    += chunk
                    last_rx  = time.monotonic()
                    deadline = max(deadline, last_rx + 2.0)
                    chunks_read += 1
                    if progress_cb and chunks_read % 10 == 0:
                        progress_cb(len(data))
                else:
                    time.sleep(0.01)
            except BlockingIOError:
                if time.monotonic() - last_rx > 2.0:
                    raise RuntimeError(
                        f'idle gap during binary read ({len(data)}/{nbytes} bytes)')
                time.sleep(0.01)

        if progress_cb and chunks_read % 10 != 0:
            progress_cb(len(data))

        # Phase 3: drain until ---END--- (best-effort, don't fail if missing)
        end_deadline = time.monotonic() + 2.0
        while time.monotonic() < end_deadline:
            try:
                chunk = os.read(self._fd, 4096)
                if chunk:
                    buf += chunk
                    if b'---END---' in buf:
                        break
                else:
                    time.sleep(0.01)
            except BlockingIOError:
                time.sleep(0.01)

        return data

    def send(self, cmd, timeout=4.0):
        """Send a command and return extracted response text, or exit on failure."""
        termios.tcflush(self._fd, termios.TCIFLUSH)
        os.write(self._fd, (cmd + '\r\n').encode())
        result = self._extract(self._read_until_end(timeout))
        if result is None:
            sys.exit(f'ERROR: no response from device (cmd={cmd!r})')
        return result

    def get_state(self):
        """Return the device state string (e.g. FLIGHT_STATE_IDLE)."""
        for line in self.send('status').splitlines():
            if line.startswith('state:'):
                return line.split(':', 1)[1].strip()
        sys.exit('ERROR: could not parse device state from status response')

    def require_idle(self):
        s = self.get_state()
        if s != _STATE_IDLE:
            sys.exit(f'ERROR: device is not IDLE (state={s}). Aborting.')

    def enter_transfer(self):
        self.send('transfer', timeout=3.0)
        time.sleep(0.1)
        termios.tcflush(self._fd, termios.TCIFLUSH)

    def exit_transfer(self):
        # Retry resume up to 3 times: after a large rm the USB TX buffer may
        # still be draining, delaying the response past the idle-gap timeout.
        for attempt in range(3):
            if attempt:
                time.sleep(0.5)
            termios.tcflush(self._fd, termios.TCIFLUSH)
            os.write(self._fd, b'resume\r\n')
            raw = self._read_until_end(timeout=3.0)
            if b'---END---' in raw:
                return
        # If all retries fail the device will auto-resume after its 30s timeout.
        print('WARNING: resume got no response; device will auto-resume in ≤30s',
              file=sys.stderr)


@contextmanager
def _transfer(device):
    """Context manager: check IDLE, enter TRANSFER, yield, then resume."""
    device.require_idle()
    device.enter_transfer()
    try:
        yield device
    finally:
        device.exit_transfer()


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def _parse_ls(output):
    """Return list of (filename, size_bytes) for flight files from 'ls' output."""
    result = []
    for line in output.splitlines():
        parts = line.split()
        if len(parts) >= 2 and parts[0].startswith('flight_'):
            try:
                result.append((parts[0], int(parts[1])))
            except ValueError:
                pass
    return result


# ---------------------------------------------------------------------------
# Quick commands — no TRANSFER state required
# ---------------------------------------------------------------------------

def cmd_status(device, args):
    """Print device status. Exits non-zero if not IDLE (safe to run any time)."""
    output = device.send('status')
    print(output)
    s = None
    for line in output.splitlines():
        if line.startswith('state:'):
            s = line.split(':', 1)[1].strip()
    if s != _STATE_IDLE:
        sys.exit(f'Not IDLE (state={s})')


def cmd_ping(device, args):
    device.require_idle()
    print(device.send('ping'))


def cmd_help(device, args):
    device.require_idle()
    print(device.send('help'))


def cmd_trigger(device, args):
    device.require_idle()
    result = device.send('trigger')
    if 'denied' in result.lower():
        sys.exit(f'ERROR: {result}')
    print(result)


# ---------------------------------------------------------------------------
# Data commands — device enters TRANSFER state for the duration
# ---------------------------------------------------------------------------

def cmd_ls(device, args):
    with _transfer(device) as dev:
        print(dev.send('ls'))


def cmd_cat(device, args):
    with _transfer(device) as dev:
        flights = {f: sz for f, sz in _parse_ls(dev.send('ls'))}
        if args.file not in flights:
            sys.exit(f'ERROR: {args.file} not found')
        nbytes = flights[args.file]
        if nbytes == 0:
            print(f'{args.file}: empty')
            return
        data = dev.read_binary(f'cat {args.file}', nbytes)
        for offset in range(0, len(data), 16):
            chunk = data[offset:offset + 16]
            hex_part = ' '.join(f'{b:02x}' for b in chunk)
            print(f'{offset:08x}  {hex_part}')


def cmd_rm(device, args):
    confirm = input(f'Delete {args.file} from device? [y/N] ')
    if confirm.lower() != 'y':
        sys.exit('Aborted.')
    with _transfer(device) as dev:
        result = dev.send(f'rm {args.file}')
        if 'error' in result.lower() or 'denied' in result.lower():
            sys.exit(f'FAILED: {result}')
        print(f'Deleted {args.file}')


_RECORD_FMT  = '<qfff'
_RECORD_SIZE = struct.calcsize(_RECORD_FMT)  # 20 bytes


def cmd_pull(device, args):
    with _transfer(device) as dev:
        filename = args.file
        if not filename:
            flights = _parse_ls(dev.send('ls'))
            candidates = sorted(f for f, sz in flights if sz > 0)
            if not candidates:
                sys.exit('No flight data on device.')
            filename = candidates[-1]

        # Get file size via send() first (parses the size: header from cat output)
        # We use a quick send to get the size header, but that also reads the data.
        # Instead, get size from ls output.
        flights = {f: sz for f, sz in _parse_ls(dev.send('ls'))}
        if filename not in flights:
            sys.exit(f'ERROR: {filename} not found on device')
        expected_bytes = flights[filename]
        if expected_bytes == 0:
            sys.exit(f'ERROR: {filename} is empty')
        expected_records = expected_bytes // _RECORD_SIZE
        print(f'Downloading {filename} ({expected_bytes} bytes, '
              f'{expected_records} samples) ...')

        def progress(received):
            pct = received * 100 // expected_bytes
            print(f'\r  {received}/{expected_bytes} bytes ({pct}%)',
                  end='', flush=True)

        try:
            data = dev.read_binary(f'cat {filename}',
                                   expected_bytes, progress_cb=progress)
        except RuntimeError as e:
            print(f'\nERROR: transfer failed: {e}')
            sys.exit(1)

        print()  # newline after progress

        if len(data) != expected_bytes:
            print(f'ERROR: received {len(data)} bytes but expected {expected_bytes}')
            sys.exit(1)

        if len(data) % _RECORD_SIZE != 0:
            sys.exit(f'ERROR: {len(data)} bytes is not a multiple of '
                     f'{_RECORD_SIZE} (corrupt file?)')

        out_path = filename + '.csv'
        with open(out_path, 'w') as f:
            f.write('timestamp_ns,ax_g,ay_g,az_g\n')
            for offset in range(0, len(data), _RECORD_SIZE):
                ts_us, ax, ay, az = struct.unpack_from(_RECORD_FMT, data, offset)
                f.write(f'{ts_us * 1000},{ax:.4f},{ay:.4f},{az:.4f}\n')

        records = len(data) // _RECORD_SIZE
        print(f'Saved {out_path} ({os.path.getsize(out_path)} bytes, {records} samples)')


def cmd_df(device, args):
    with _transfer(device) as dev:
        print(dev.send('status'))
        print('---')
        print(dev.send('ls'))


def cmd_wipe(device, args):
    with _transfer(device) as dev:
        if args.file:
            confirm = input(f'Delete {args.file} from device? [y/N] ')
            if confirm.lower() != 'y':
                sys.exit('Aborted.')
            result = dev.send(f'rm {args.file}')
            if 'error' in result.lower() or 'denied' in result.lower():
                sys.exit(f'FAILED: {result}')
            print(f'Deleted {args.file}')
        else:
            flights = _parse_ls(dev.send('ls'))
            files   = [f for f, _ in flights]
            if not files:
                print('No files to delete.')
                return
            print('\n'.join(files))
            confirm = input('Delete ALL listed files? [y/N] ')
            if confirm.lower() != 'y':
                sys.exit('Aborted.')
            ok = True
            for f in files:
                result = dev.send(f'rm {f}')
                if 'error' in result.lower() or 'denied' in result.lower():
                    print(f'FAILED {f}: {result}', file=sys.stderr)
                    ok = False
                else:
                    print(f'Deleted {f}')
            if not ok:
                sys.exit(1)


def cmd_monitor(port, args):
    """Stream raw serial output from the device (read-only). Ctrl-C to stop."""
    fd = os.open(port, os.O_RDONLY | os.O_NOCTTY | os.O_NONBLOCK)
    try:
        attrs    = termios.tcgetattr(fd)
        attrs[0] = 0                                              # iflag
        attrs[1] = 0                                              # oflag
        attrs[2] = termios.CS8 | termios.CREAD | termios.CLOCAL  # 8N1, no modem ctl
        attrs[3] = 0                                              # lflag: raw
        attrs[4] = termios.B115200
        attrs[5] = termios.B115200
        attrs[6][termios.VMIN]  = 0
        attrs[6][termios.VTIME] = 0
        termios.tcsetattr(fd, termios.TCSANOW, attrs)
        buf = b''
        while True:
            try:
                chunk = os.read(fd, 4096)
                if chunk:
                    buf += chunk
                    while b'\n' in buf:
                        line, buf = buf.split(b'\n', 1)
                        sys.stdout.buffer.write(line + b'\n')
                        sys.stdout.buffer.flush()
                else:
                    time.sleep(0.01)
            except BlockingIOError:
                time.sleep(0.01)
    except KeyboardInterrupt:
        pass
    finally:
        os.close(fd)


def cmd_diag(device, args):
    print('=== Force-4 Diagnostics ===')
    print(f'Port: {device.port}')
    print()
    with _transfer(device) as dev:
        print('--- Ping ---')
        ping = dev.send('ping')
        if 'pong' in ping:
            print('OK: device responded to ping')
        else:
            print(f'FAIL: no pong\n  Got: {ping}')
            sys.exit(1)
        print()
        print('--- Status ---')
        print(dev.send('status'))
        print()
        print('--- Storage ---')
        print(dev.send('ls'))
    print()
    print('=== All checks passed ===')


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

_COMMANDS = {
    # quick
    'status':  cmd_status,
    'ping':    cmd_ping,
    'help':    cmd_help,
    'trigger': cmd_trigger,
    # data
    'ls':      cmd_ls,
    'cat':     cmd_cat,
    'rm':      cmd_rm,
    'pull':    cmd_pull,
    'df':      cmd_df,
    'wipe':    cmd_wipe,
    'diag':    cmd_diag,
}


def main():
    parser = argparse.ArgumentParser(
        prog='mission-control',
        description='Force-4 flight data manager',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            'Quick commands (no TRANSFER state):\n'
            '  status, ping, help, trigger\n'
            '\n'
            'Data commands (device enters TRANSFER state for safety):\n'
            '  ls, cat, rm, pull, df, wipe, diag\n'
            '\n'
            'All commands except "status" require the device to be IDLE.'
        ),
    )
    parser.add_argument('--port', help='Serial port (default: auto-detect /dev/cu.usbmodem*)')
    sub = parser.add_subparsers(dest='command', required=True)

    # Quick commands
    sub.add_parser('status',  help='Show device status (safe to run any time)')
    sub.add_parser('ping',    help='Test connection')
    sub.add_parser('help',    help='Show device command help')
    sub.add_parser('trigger', help='Manually start a flight recording (IDLE only)')
    sub.add_parser('monitor', help='Stream raw serial output (read-only, Ctrl-C to stop)')

    # Data commands
    sub.add_parser('ls',  help='List flight files on device')
    p = sub.add_parser('cat',  help='Print flight file contents to stdout')
    p.add_argument('file')
    p = sub.add_parser('rm',   help='Delete a specific flight file from device')
    p.add_argument('file')
    p = sub.add_parser('pull', help='Download flight CSV to local file (default: most recent)')
    p.add_argument('file', nargs='?', help='Flight filename (default: most recent non-empty)')
    sub.add_parser('df',   help='Show storage usage and flight list')
    p = sub.add_parser('wipe', help='Delete flight file(s) from device (default: all)')
    p.add_argument('file', nargs='?', help='Flight filename (default: all, with confirmation)')
    sub.add_parser('diag', help='Run device health diagnostics')

    args = parser.parse_args()
    port = args.port or _find_port()

    if args.command == 'monitor':
        cmd_monitor(port, args)
        return

    with Device(port) as device:
        _COMMANDS[args.command](device, args)


if __name__ == '__main__':
    main()
